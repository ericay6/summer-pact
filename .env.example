# ──────────────────────────────────────────────────────────────────────────
# Summer Pact — environment variables
# ──────────────────────────────────────────────────────────────────────────
# The app runs in DEMO MODE (local, no backend) when these are missing.
# Fill these in to enable real Supabase auth, database, and proof uploads.
#
# Get them from: Supabase Dashboard → Project Settings → API
# ──────────────────────────────────────────────────────────────────────────

# Public URL of your Supabase project, e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Public "anon" key (safe to expose to the browser; RLS protects your data)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Name of the Storage bucket used for receipt proof uploads.
# Create a PUBLIC bucket with this name in Supabase → Storage.
NEXT_PUBLIC_SUPABASE_PROOF_BUCKET=proofs

# Base URL used for magic-link auth redirects (no trailing slash).
# Local: http://localhost:3000   Prod: https://your-app.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Optional: AI provider (not required for MVP) ──────────────────────────
# The app ships with deterministic template generators in src/lib/ai.ts.
# Add a key here later to swap in Claude/OpenAI. Keep this server-side only.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
